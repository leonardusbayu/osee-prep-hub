# Local development secrets — DO NOT COMMIT REAL VALUES
# Copy this file to .dev.vars and fill with real values for local dev.

SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_ANON_KEY=placeholder
SUPABASE_SERVICE_KEY=placeholder

# PostgreSQL connection string for one-off CLI tasks (apply-schema, verify-schema).
# Get the real password from the Supabase dashboard → Settings → Database → Connection string.
# NEVER commit the real value.
DATABASE_URL=postgresql://postgres:REPLACE_ME@db.PROJECT_REF.supabase.co:5432/postgres

JWT_SECRET=local-dev-secret-replace-in-production-xxxxxxxxxxxxxxxx
JWT_EXPIRY=7d

OPENAI_API_KEY=placeholder

EDUBOT_API_URL=https://edubot-webapp.pages.dev
EDUBOT_INTERNAL_SECRET=placeholder

WEBHOOK_SECRET_IBT=placeholder
WEBHOOK_SECRET_ITP=placeholder
WEBHOOK_SECRET_IELTS=placeholder
WEBHOOK_SECRET_TOEIC=placeholder
WEBHOOK_SECRET_BOOKING=placeholder
WEBHOOK_SECRET_EDUBOT=placeholder

WEBAPP_URL=http://localhost:8787

TRIPAY_API_KEY=placeholder
TRIPAY_PRIVATE_KEY=placeholder
TRIPAY_MERCHANT_CODE=placeholder

TELEGRAM_BOT_TOKEN=placeholder
TELEGRAM_CHANNEL_ID=-1003884450070

OSEE_BOOKING_API_URL=https://osee.co.id/api/hub
OSEE_BOOKING_API_SECRET=placeholder

# Email (Resend) — for report delivery + partner teacher invitations.
# Dev: use Resend's sandbox sender onboarding@resend.dev (no DNS needed).
# Production: verify osee.co.id in the Resend dashboard and set MAIL_FROM.
RESEND_API_KEY=placeholder
MAIL_FROM=OSEE Prep Hub <noreply@osee.co.id>

# OSEE Passport (Ed25519 credential signing) — Wave 1 T3.
# Generate a real keypair with: node scripts/gen-passport-key.mjs
PASSPORT_SIGNING_KEY=placeholder-64-hex-chars
PASSPORT_KEY_ID=placeholder

# LiveKit (live classes) — Wave 2 T12.
LIVEKIT_API_KEY=placeholder
LIVEKIT_API_SECRET=placeholder
LIVEKIT_URL=wss://placeholder.livekit.cloud

# Sentry error tracking — Wave 1 T7.
SENTRY_DSN=

# Ambassador equity implied value (IDR) — Wave 5 T37.
OSEE_VALUATION_IDR=100000000000

ENVIRONMENT=development
